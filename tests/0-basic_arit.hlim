decl(target 11)
assert([7+4] == target "basic addition failed")
assert([22/2] == target "basic div. failed")
assert([20-4+2-1-6] == target "left assoc. failed")
assert([10/2/1] == 5 "div. assoc. failed")
assert([3+4*2] == target "operator prec. failed")
assert([[3+4]*2] == 14 "expr. grouping failed")
assert([2*[3+[8/4 ]]] == 10 "deep nesting failed")

assert(54.01 gr 54 "Greater than comparison failed")
assert(![54 gr 54] "Greater than comparison with equal nums failed")

assert(54 le 54.1 "Lesser than comparison failed")
assert(![54 le 54] "Lesser than comparison with equal nums failed")

assert(![54 == nil] "Number comparison with nil failed")
assert(nil == nil "nil comparison with nil failed")

